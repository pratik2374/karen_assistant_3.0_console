"product_scope": {
    "triggers": ["install", "revenue", "amount", "contract"],
    "options": {
        "1": ("Solar only",    "Product_Category LIKE '%Solar%'"),
        "2": ("Roofing only",  "Product_Category LIKE '%Roof%'"),
        "3": ("Battery only",  "Product_Category LIKE '%Battery%'"),
        "4": ("R&R only",      "Product_Category LIKE '%R&R%'"),
        "5": ("All combined",  "no product filter"),
    }
}

"deal_stage": {
    "triggers": ["pipeline", "contract", "install pending", "stage", "active deals"],
    "options": {
        "1": ("All stages", "no stage filter"),
        "2": ("Contract signed only", "Stage LIKE '4%'"),
        "3": ("Installation in progress", "Stage LIKE '6%' OR Stage LIKE '7%'"),
        "4": ("Complete projects", "Stage LIKE '10%'"),
        "5": ("Lost deals", "Stage LIKE '10: Lost' OR Stage LIKE '11: Lost'"),
    }
}

"DATE": {
    "triggers": ["install", "signed", "demo", "last year", "this year", "last month"],
    "resolution_options": {
        "solar":   "Date_Contract_Signed or Actual_Install_Date",
        "roofing": "Roofing_Contract_Date or Roofing_Install_Date",
        "battery": "Battery_Contract_Date or Battery_Install_Date",
        "payment": "Payment_Due_Date",
    },
    "ask": "Which date milestone — contract signed, install date, demo date, or payment date?"
},

"METRIC": {
    "triggers": ["commission", "earnings", "revenue", "paid", "earned"],
    "resolution_options": {
        "gross":    "commission.Commission_Amount",
        "net":      "Commission_Amount - commission_reductions.Reductions",
        "paid":     "payment.Amount WHERE Payment_Status = Approved",
        "deals":    "COUNT(DISTINCT Sales_Force_Id)",
    },
    "ask": "Which metric — gross commission earned, net after deductions, approved payments received, or deal count?"
},
